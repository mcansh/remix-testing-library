{
  "name": "@remix-run/interaction",
  "version": "0.5.0",
  "description": "Like components but for events",
  "author": "Ryan Florence <rpflorence@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/events"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/events#readme",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./form": {
      "types": "./dist/lib/interactions/form.d.ts",
      "default": "./dist/lib/interactions/form.js"
    },
    "./keys": {
      "types": "./dist/lib/interactions/keys.d.ts",
      "default": "./dist/lib/interactions/keys.js"
    },
    "./popover": {
      "types": "./dist/lib/interactions/popover.d.ts",
      "default": "./dist/lib/interactions/popover.js"
    },
    "./press": {
      "types": "./dist/lib/interactions/press.d.ts",
      "default": "./dist/lib/interactions/press.js"
    }
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20251125.1",
    "@vitest/browser": "^3.2.4",
    "esbuild": "^0.25.5",
    "playwright": "^1.53.1",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "demos": "cd demos && pnpm start",
    "size": "esbuild src/index.ts --bundle --minify --outfile=.temp-bundle.js --format=esm && echo \"📦 Bundle sizes:\" && echo \"   Uncompressed: $(ls -lah .temp-bundle.js | awk '{print $5}')\" && echo \"   Gzipped: $(gzip -c .temp-bundle.js | wc -c | tr -d ' ') bytes\" && rm .temp-bundle.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit"
  }
}